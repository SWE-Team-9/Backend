# Server
PORT=3006
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# PostgreSQL Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Storage (local = save to uploads/ folder, s3 = AWS S3)
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads

# JWT
JWT_SECRET=Pretty_secure_because_it_was_done_by_mohan
JWT_REFRESH_SECRET=Pretty_secure_because_it_was_done_by_mohan
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Auth Cookie Security
AUTH_COOKIE_SECURE=false

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=no-reply@iqa3.com

# Google reCAPTCHA
RECAPTCHA_SECRET=your_recaptcha_secret_key

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AWS S3 (Audio Storage)
AWS_REGION=your_aws_region
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY=your_private_key

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800
