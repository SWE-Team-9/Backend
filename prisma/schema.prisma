// =============================================================================
// Spotly — Prisma Schema (Full)
// Implements every ERD table except API_CLIENT / API_AUTH_CODE / API_ACCESS_TOKEN
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext, pgcrypto]
}

// =============================================================================
// Enums
// =============================================================================

// ── User & Auth ───────────────────────────────────────────────────────────────

enum SystemRole {
  USER
  MODERATOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
  SOUNDCLOUD
  OTHER
}

enum DevicePlatform {
  WEB
  ANDROID
  IOS
  DESKTOP
}

enum AccountType {
  LISTENER
  ARTIST
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

enum SocialPlatform {
  INSTAGRAM
  X
  TIKTOK
  YOUTUBE
  WEBSITE
  FACEBOOK
  TWITTER
  SPOTIFY
  APPLE_MUSIC
  BANDCAMP
  SOUNDCLOUD
  PATREON
  TWITCH
  DISCORD
  LINKEDIN
  GITHUB
  OTHER
}

// ── Track ─────────────────────────────────────────────────────────────────────

enum TrackVisibility {
  PUBLIC
  PRIVATE
}

enum TrackAccessLevel {
  PLAYABLE
  PREVIEW
  BLOCKED
}

enum TrackStatus {
  PROCESSING
  FINISHED
  FAILED
  REMOVED
}

enum ModerationState {
  VISIBLE
  HIDDEN
  REMOVED
}

enum TrackLicense {
  ALL_RIGHTS_RESERVED
  CC_BY
  CC_BY_SA
  CC_BY_NC
  CC_BY_NC_SA
  CC_BY_ND
  CC_BY_NC_ND
}

enum FileRole {
  ORIGINAL
  STREAM
  PREVIEW
  WAVEFORM
  ARTWORK
}

enum FileStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// ── Play ──────────────────────────────────────────────────────────────────────

enum PlaySource {
  TRACK
  PLAYLIST
  SEARCH
  FEED
  MESSAGE
  EMBED
}

enum PlayDeviceType {
  WEB
  ANDROID
  IOS
  DESKTOP
}

// ── Playlist ──────────────────────────────────────────────────────────────────

enum PlaylistType {
  PLAYLIST
  ALBUM
  EP
  SINGLE
  COMPILATION
}

enum PlaylistVisibility {
  PUBLIC
  SECRET
}

// ── Activity ──────────────────────────────────────────────────────────────────

enum ActivityEventType {
  TRACK_PUBLISHED
  REPOST
  FOLLOW
  LIKE
  PLAYLIST_CREATED
}

enum RepeatMode {
  OFF
  ONE
  ALL
}

// ── Messaging ─────────────────────────────────────────────────────────────────

enum ConversationKind {
  DIRECT
}

enum MessageType {
  TEXT
  TRACK_SHARE
  PLAYLIST_SHARE
  SYSTEM
}

// ── Notifications ─────────────────────────────────────────────────────────────

enum NotificationEntityType {
  TRACK
  COMMENT
  USER
  PLAYLIST
  MESSAGE
}

enum NotificationEventType {
  FOLLOW
  LIKE
  REPOST
  COMMENT
  MESSAGE
  REPORT_RESOLVED
  SUBSCRIPTION
  ACCOUNT_SUSPENDED
  ACCOUNT_BANNED
  ACCOUNT_RESTORED
}

enum DeliveryChannel {
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

// ── Moderation ────────────────────────────────────────────────────────────────

enum ReportTargetType {
  TRACK
  USER
  PLAYLIST
  COMMENT
}

enum ReportReason {
  COPYRIGHT
  INAPPROPRIATE
  SPAM
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum ReportCategory {
  COPYRIGHT
  INAPPROPRIATE
  SPAM
  HARASSMENT
  OTHER
}

enum ModerationActionType {
  WARN_USER
  SUSPEND_USER
  BAN_USER
  HIDE_TRACK
  REMOVE_TRACK
  HIDE_PLAYLIST
  REMOVE_PLAYLIST
  HIDE_COMMENT
  RESTORE_CONTENT
}

// ── Subscriptions ─────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  PRO
  GO_PLUS
}

enum BillingInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

// =============================================================================
// Core User & Auth
// =============================================================================

model User {
  id             String        @id @default(uuid()) @db.Uuid
  email          String        @unique @db.Citext
  passwordHash   String?       @map("password_hash")
  systemRole     SystemRole    @default(USER) @map("system_role")
  accountStatus  AccountStatus @default(ACTIVE) @map("account_status")
  suspendedUntil DateTime?     @map("suspended_until") @db.Timestamptz
  isVerified     Boolean       @default(false) @map("is_verified")
  dateOfBirth    DateTime      @map("date_of_birth") @db.Date
  gender         Gender
  lastLoginAt    DateTime?     @map("last_login_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz

  // Relations
  profile        UserProfile?
  authIdentities AuthIdentity[]
  devices        UserDevice[]

  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  emailChangeRequests      EmailChangeRequest[]
  favoriteGenres           UserFavoriteGenre[]
  socialLinks              UserSocialLink[]
  handleHistory            UserHandleHistory[]
  following                UserFollow[]                @relation("Follower")
  followers                UserFollow[]                @relation("Following")
  blockedUsers             UserBlock[]                 @relation("Blocker")
  blockedBy                UserBlock[]                 @relation("Blocked")
  tracks                   Track[]
  likes                    Like[]
  reposts                  Repost[]
  comments                 Comment[]
  playEvents               PlayEvent[]
  playlists                Playlist[]
  playlistLikes            PlaylistLike[]
  playlistReposts          PlaylistRepost[]
  actorEvents              ActivityEvent[]             @relation("Actor")
  targetEvents             ActivityEvent[]             @relation("TargetUser")
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  receivedNotifications    Notification[]              @relation("NotificationRecipient")
  triggeredNotifications   Notification[]              @relation("NotificationActor")
  submittedReports         ModerationReport[]          @relation("Reporter")
  reportedIn               ModerationReport[]          @relation("ReportedUser")
  executedActions          ModerationAction[]          @relation("AdminAction")
  receivedActions          ModerationAction[]          @relation("TargetUserAction")
  subscriptions            UserSubscription[]
  offlineDownloads         OfflineDownload[]
  authSessions             Session[]                   @relation("authSessions")
  UserSession              UserSession[]
  apiAuthCodes             ApiAuthCode[]
  apiAccessTokens          ApiAccessToken[]
  playbackProgress         PlaybackProgress[]
  playerSession            PlayerSession?
  reportsSubmitted         Report[]                    @relation("ReportReporter")
  reportsResolved          Report[]                    @relation("ReportResolver")
  appealsSubmitted         Appeal[]                    @relation("AppealUser")
  appealsResolved          Appeal[]                    @relation("AppealResolver")
  searchIndex              UserSearchIndexable?
  notificationPreference   UserNotificationPreference?
  billing                  UserBilling?
  paymentMethods           PaymentMethod[]
  trialRedemptions         TrialRedemption[]

  @@index([email])
  @@index([accountStatus])
  @@index([deletedAt])
  @@map("users")
}

model UserSearchIndexable {
  userId       String   @id @map("user_id") @db.Uuid
  username     String   @db.Citext
  displayName  String   @map("display_name")
  searchVector String   @map("search_vector") @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([searchVector(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("user_search_indexable")
}

model UserNotificationPreference {
  userId   String  @id @map("user_id") @db.Uuid
  likes    Boolean @default(true)
  comments Boolean @default(true)
  follows  Boolean @default(true)
  reposts  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

model UserProfile {
  userId        String            @id @map("user_id") @db.Uuid
  handle        String            @unique @db.Citext
  displayName   String            @map("display_name")
  bio           String?           @db.Text
  location      String?
  avatarUrl     String?           @map("avatar_url")
  coverPhotoUrl String?           @map("cover_photo_url")
  accountType   AccountType       @default(LISTENER) @map("account_type")
  visibility    ProfileVisibility @default(PUBLIC)
  likesVisible  Boolean           @default(true) @map("likes_visible")
  websiteUrl    String?           @map("website_url")
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([handle])
  @@index([handle(ops: raw("gin_trgm_ops")), displayName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("user_profiles")
}

model AuthIdentity {
  id                    String       @id @default(uuid()) @db.Uuid
  userId                String       @map("user_id") @db.Uuid
  provider              AuthProvider
  providerUserId        String?      @map("provider_user_id")
  providerEmail         String?      @map("provider_email") @db.Citext
  accessTokenEncrypted  String?      @map("access_token_encrypted")
  refreshTokenEncrypted String?      @map("refresh_token_encrypted")
  tokenExpiresAt        DateTime?    @map("token_expires_at") @db.Timestamptz
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_identities")
}

model UserDevice {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  platform         DevicePlatform
  deviceName       String?        @map("device_name")
  deviceIdentifier String?        @map("device_identifier")
  pushToken        String?        @map("push_token")
  isActive         Boolean        @default(true) @map("is_active")
  lastSeenAt       DateTime?      @map("last_seen_at") @db.Timestamptz
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz

  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions               UserSession[]
  notificationDeliveries NotificationDelivery[]
  offlineDownloads       OfflineDownload[]

  @@index([userId])
  @@index([userId, isActive])
  @@map("user_devices")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceId         String    @map("device_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  ipAddress        String?   @map("ip_address") @db.Inet
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  device     UserDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  playEvents PlayEvent[]

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([userId, revokedAt])
  @@map("user_sessions")
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailChangeRequest {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  newEmail   String    @map("new_email") @db.Citext
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_change_requests")
}

model ApiClient {
  id               String   @id @default(uuid()) @db.Uuid
  clientId         String   @unique @map("client_id")
  clientSecretHash String   @map("client_secret_hash")
  name             String   @db.VarChar(255)
  description      String?
  homepageUrl      String?  @map("homepage_url")
  redirectUris     String[] @map("redirect_uris")
  allowedScopes    String[] @default(["read"]) @map("allowed_scopes")
  isActive         Boolean  @default(true) @map("is_active")
  rateLimit        Int      @default(1000) @map("rate_limit")
  rateLimitWindow  Int      @default(3600) @map("rate_limit_window")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  authCodes    ApiAuthCode[]
  accessTokens ApiAccessToken[]

  @@index([clientId])
  @@map("api_clients")
}

model ApiAuthCode {
  id                  String    @id @default(uuid()) @db.Uuid
  clientId            String    @map("client_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  codeHash            String    @unique @map("code_hash")
  scope               String    @db.VarChar(255)
  codeChallenge       String?   @map("code_challenge")
  codeChallengeMethod String?   @map("code_challenge_method") @db.VarChar(50)
  redirectUri         String    @map("redirect_uri") @db.VarChar(2048)
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz
  consumedAt          DateTime? @map("consumed_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  client ApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([codeHash])
  @@map("api_auth_codes")
}

model ApiAccessToken {
  id               String    @id @default(uuid()) @db.Uuid
  clientId         String    @map("client_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  accessTokenHash  String    @unique @map("access_token_hash")
  refreshTokenHash String?   @unique @map("refresh_token_hash")
  scope            String    @db.VarChar(255)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  refreshExpiresAt DateTime? @map("refresh_expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  client ApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([accessTokenHash])
  @@map("api_access_tokens")
}

// =============================================================================
// User Social & Identity
// =============================================================================

model Genre {
  id   Int    @id @default(autoincrement()) @db.SmallInt
  name String @unique @db.Citext
  slug String @unique @db.Citext

  userFavorites UserFavoriteGenre[]
  tracks        Track[]
  playlists     Playlist[]

  @@map("genres")
}

model UserFavoriteGenre {
  userId    String   @map("user_id") @db.Uuid
  genreId   Int      @map("genre_id") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([userId, genreId])
  @@map("user_favorite_genres")
}

model UserSocialLink {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  platform  SocialPlatform
  url       String
  sortOrder Int            @default(0) @map("sort_order")
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_social_links")
}

model UserHandleHistory {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  handle    String    @db.Citext
  fullPath  String    @unique @map("full_path")
  isCurrent Boolean   @default(false) @map("is_current")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  retiredAt DateTime? @map("retired_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([handle])
  @@map("user_handle_history")
}

model UserFollow {
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

model UserBlock {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockerId])
  @@map("user_blocks")
}

// =============================================================================
// Tracks
// =============================================================================

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique @db.Citext
  slug String @unique @db.Citext

  trackTags TrackTag[]

  @@map("tags")
}

model Track {
  id                  String           @id @default(uuid()) @db.Uuid
  uploaderId          String           @map("uploader_id") @db.Uuid
  primaryGenreId      Int?             @map("primary_genre_id") @db.SmallInt
  title               String
  slug                String           @db.Citext
  description         String?          @db.Text
  releaseDate         DateTime?        @map("release_date") @db.Date
  durationMs          Int?             @map("duration_ms")
  waveformData        Float[]          @map("waveform_data")
  visibility          TrackVisibility  @default(PUBLIC)
  accessLevel         TrackAccessLevel @default(PLAYABLE) @map("access_level")
  status              TrackStatus      @default(PROCESSING)
  moderationState     ModerationState  @default(VISIBLE) @map("moderation_state")
  license             TrackLicense     @default(ALL_RIGHTS_RESERVED)
  allowComments       Boolean          @default(true) @map("allow_comments")
  downloadable        Boolean          @default(false)
  coverArtUrl         String?          @map("cover_art_url")
  secretToken         String?          @map("secret_token")
  publishedAt         DateTime?        @map("published_at") @db.Timestamptz
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?        @map("deleted_at") @db.Timestamptz
  // Module 12: set true when track auto-hidden due to plan-limit downgrade;
  // reset to false on upgrade. Never confuse with user-set visibility.
  hiddenByPlanLimit   Boolean          @default(false) @map("hidden_by_plan_limit")
  hiddenByPlanLimitAt DateTime?        @map("hidden_by_plan_limit_at") @db.Timestamptz

  uploader          User                    @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  primaryGenre      Genre?                  @relation(fields: [primaryGenreId], references: [id], onDelete: SetNull)
  files             TrackFile[]
  tags              TrackTag[]
  availabilityRules TrackAvailabilityRule[]
  permalinkHistory  TrackPermalinkHistory[]
  likes             Like[]
  reposts           Repost[]
  comments          Comment[]
  playEvents        PlayEvent[]
  playlistTracks    PlaylistTrack[]
  activityEvents    ActivityEvent[]
  messageShares     MessageShare[]
  notifications     Notification[]
  moderationReports ModerationReport[]
  moderationActions ModerationAction[]
  offlineDownloads  OfflineDownload[]
  dailyStats        TrackDailyStat[]
  playbackProgress  PlaybackProgress[]
  playerSessions    PlayerSession[]         @relation("PlayerSessionTrack")

  @@index([uploaderId])
  @@index([slug])
  @@index([status])
  @@index([visibility, moderationState])
  @@index([deletedAt])
  @@index([title(ops: raw("gin_trgm_ops")), description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("tracks")
}

model TrackFile {
  id            String     @id @default(uuid()) @db.Uuid
  trackId       String     @map("track_id") @db.Uuid
  fileRole      FileRole   @map("file_role")
  storageKey    String     @map("storage_key")
  mimeType      String     @map("mime_type")
  format        String?
  bitrateKbps   Int?       @map("bitrate_kbps")
  sampleRateHz  Int?       @map("sample_rate_hz")
  channels      Int?
  fileSizeBytes BigInt?    @map("file_size_bytes")
  status        FileStatus @default(PENDING)
  isCurrent     Boolean    @default(false) @map("is_current")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([trackId, fileRole, isCurrent])
  @@map("track_files")
}

model TrackTag {
  trackId   String   @map("track_id") @db.Uuid
  tagId     Int      @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([trackId, tagId])
  @@map("track_tags")
}

model TrackAvailabilityRule {
  id             String           @id @default(uuid()) @db.Uuid
  trackId        String           @map("track_id") @db.Uuid
  requiredPlanId String?          @map("required_plan_id") @db.Uuid
  countryCode    String?          @map("country_code") @db.Char(2)
  accessLevel    TrackAccessLevel @map("access_level")
  startsAt       DateTime?        @map("starts_at") @db.Timestamptz
  endsAt         DateTime?        @map("ends_at") @db.Timestamptz

  track        Track             @relation(fields: [trackId], references: [id], onDelete: Cascade)
  requiredPlan SubscriptionPlan? @relation(fields: [requiredPlanId], references: [id], onDelete: SetNull)

  @@index([trackId])
  @@map("track_availability_rules")
}

model TrackPermalinkHistory {
  id        String    @id @default(uuid()) @db.Uuid
  trackId   String    @map("track_id") @db.Uuid
  slug      String    @db.Citext
  fullPath  String    @unique @map("full_path")
  isCurrent Boolean   @default(false) @map("is_current")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  retiredAt DateTime? @map("retired_at") @db.Timestamptz

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@map("track_permalink_history")
}

model Like {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  trackId   String   @map("track_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([trackId])
  @@map("track_likes")
}

model Repost {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  trackId   String   @map("track_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([trackId])
  @@map("track_reposts")
}

model Comment {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  trackId         String          @map("track_id") @db.Uuid
  content         String          @db.Text
  timestampAt     Int             @map("timestamp_at")
  moderationState ModerationState @default(VISIBLE) @map("moderation_state")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  track             Track              @relation(fields: [trackId], references: [id], onDelete: Cascade)
  notifications     Notification[]
  moderationReports ModerationReport[]
  moderationActions ModerationAction[]

  @@index([trackId])
  @@index([userId])
  @@map("track_comments")
}

model PlayEvent {
  id              BigInt         @id @default(autoincrement())
  userId          String?        @map("user_id") @db.Uuid
  trackId         String         @map("track_id") @db.Uuid
  sessionId       String?        @map("session_id") @db.Uuid
  playlistId      String?        @map("playlist_id") @db.Uuid
  messageId       String?        @map("message_id") @db.Uuid
  source          PlaySource
  deviceType      PlayDeviceType @map("device_type")
  countryCode     String?        @map("country_code") @db.Char(2)
  listenedMs      Int?           @map("listened_ms")
  completionRatio Decimal?       @map("completion_ratio") @db.Decimal(5, 4)
  startedAt       DateTime       @default(now()) @map("started_at") @db.Timestamptz

  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  track    Track        @relation(fields: [trackId], references: [id], onDelete: Cascade)
  session  UserSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  playlist Playlist?    @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  message  Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([trackId])
  @@index([userId])
  @@index([startedAt])
  @@map("play_events")
}

// =============================================================================
// Playlists
// =============================================================================

model Playlist {
  id              String             @id @default(uuid()) @db.Uuid
  ownerId         String             @map("owner_id") @db.Uuid
  title           String
  slug            String             @db.Citext
  description     String?            @db.Text
  coverArtUrl     String?            @map("cover_art_url")
  coverImageUrl   String?            @map("cover_image_url")
  type            PlaylistType       @default(PLAYLIST)
  releaseDate     DateTime?          @map("release_date") @db.Date
  genreId         Int?               @map("genre_id") @db.SmallInt
  tags            String[]           @default([])
  visibility      PlaylistVisibility @default(PUBLIC)
  moderationState ModerationState    @default(VISIBLE) @map("moderation_state")
  secretToken     String?            @map("secret_token")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamptz

  owner             User                       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  genre             Genre?                     @relation(fields: [genreId], references: [id], onDelete: SetNull)
  tracks            PlaylistTrack[]
  permalinkHistory  PlaylistPermalinkHistory[]
  likes             PlaylistLike[]
  reposts           PlaylistRepost[]
  playEvents        PlayEvent[]
  activityEvents    ActivityEvent[]
  messageShares     MessageShare[]
  notifications     Notification[]
  moderationReports ModerationReport[]
  moderationActions ModerationAction[]

  @@index([ownerId])
  @@index([slug])
  @@index([genreId])
  @@index([visibility, moderationState])
  @@index([deletedAt])
  @@index([title(ops: raw("gin_trgm_ops")), description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("playlists")
}

model PlaylistTrack {
  playlistId String   @map("playlist_id") @db.Uuid
  trackId    String   @map("track_id") @db.Uuid
  position   Int
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([playlistId, trackId])
  @@index([playlistId, position])
  @@map("playlist_tracks")
}

model PlaylistPermalinkHistory {
  id         String    @id @default(uuid()) @db.Uuid
  playlistId String    @map("playlist_id") @db.Uuid
  slug       String    @db.Citext
  fullPath   String    @unique @map("full_path")
  isCurrent  Boolean   @default(false) @map("is_current")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  retiredAt  DateTime? @map("retired_at") @db.Timestamptz

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@map("playlist_permalink_history")
}

model PlaylistLike {
  userId     String   @map("user_id") @db.Uuid
  playlistId String   @map("playlist_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId])
  @@index([playlistId])
  @@map("playlist_likes")
}

model PlaylistRepost {
  userId     String   @map("user_id") @db.Uuid
  playlistId String   @map("playlist_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId])
  @@index([playlistId])
  @@map("playlist_reposts")
}

// =============================================================================
// Activity Feed
// =============================================================================

model ActivityEvent {
  id           String            @id @default(uuid()) @db.Uuid
  actorId      String            @map("actor_id") @db.Uuid
  targetUserId String?           @map("target_user_id") @db.Uuid
  eventType    ActivityEventType @map("event_type")
  trackId      String?           @map("track_id") @db.Uuid
  playlistId   String?           @map("playlist_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  actor      User      @relation("Actor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser User?     @relation("TargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  track      Track?    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playlist   Playlist? @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("activity_events")
}

// =============================================================================
// Messaging
// =============================================================================

model Conversation {
  id        String           @id @default(uuid()) @db.Uuid
  kind      ConversationKind @default(DIRECT)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId    String    @map("conversation_id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  lastReadMessageId String?   @map("last_read_message_id") @db.Uuid
  lastReadAt        DateTime? @map("last_read_at") @db.Timestamptz
  isArchived        Boolean   @default(false) @map("is_archived")
  joinedAt          DateTime  @default(now()) @map("joined_at") @db.Timestamptz

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage Message?     @relation("LastReadMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  senderId       String      @map("sender_id") @db.Uuid
  messageType    MessageType @default(TEXT) @map("message_type")
  body           String?     @db.Text
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  editedAt       DateTime?   @map("edited_at") @db.Timestamptz
  deletedAt      DateTime?   @map("deleted_at") @db.Timestamptz

  conversation           Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender                 User                      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  share                  MessageShare?
  playEvents             PlayEvent[]
  notifications          Notification[]
  lastReadByParticipants ConversationParticipant[] @relation("LastReadMessage")

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model MessageShare {
  messageId  String  @id @map("message_id") @db.Uuid
  trackId    String? @map("track_id") @db.Uuid
  playlistId String? @map("playlist_id") @db.Uuid

  message  Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  track    Track?    @relation(fields: [trackId], references: [id], onDelete: SetNull)
  playlist Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)

  @@map("message_shares")
}

// =============================================================================
// Notifications
// =============================================================================

model Notification {
  id          String                 @id @default(uuid()) @db.Uuid
  recipientId String                 @map("recipient_id") @db.Uuid
  actorId     String?                @map("actor_id") @db.Uuid
  entityType  NotificationEntityType @map("entity_type")
  trackId     String?                @map("track_id") @db.Uuid
  playlistId  String?                @map("playlist_id") @db.Uuid
  commentId   String?                @map("comment_id") @db.Uuid
  messageId   String?                @map("message_id") @db.Uuid
  eventType   NotificationEventType  @map("event_type")
  metadata    Json?                  @db.JsonB
  readAt      DateTime?              @map("read_at") @db.Timestamptz
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz

  recipient  User                   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor      User?                  @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  track      Track?                 @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playlist   Playlist?              @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  comment    Comment?               @relation(fields: [commentId], references: [id], onDelete: Cascade)
  message    Message?               @relation(fields: [messageId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([recipientId])
  @@index([recipientId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String          @id @default(uuid()) @db.Uuid
  notificationId String          @map("notification_id") @db.Uuid
  deviceId       String          @map("device_id") @db.Uuid
  channel        DeliveryChannel
  status         DeliveryStatus  @default(PENDING)
  failureReason  String?         @map("failure_reason")
  sentAt         DateTime?       @map("sent_at") @db.Timestamptz
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  device       UserDevice   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([deviceId])
  @@map("notification_deliveries")
}

// =============================================================================
// Moderation
// =============================================================================

model ModerationReport {
  id             String         @id @default(uuid()) @db.Uuid
  reporterId     String         @map("reporter_id") @db.Uuid
  reportedUserId String?        @map("reported_user_id") @db.Uuid
  trackId        String?        @map("track_id") @db.Uuid
  playlistId     String?        @map("playlist_id") @db.Uuid
  commentId      String?        @map("comment_id") @db.Uuid
  category       ReportCategory
  description    String?        @db.Text
  status         ReportStatus   @default(PENDING)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt     DateTime?      @map("resolved_at") @db.Timestamptz

  reporter     User               @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User?              @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  track        Track?             @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playlist     Playlist?          @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  comment      Comment?           @relation(fields: [commentId], references: [id], onDelete: Cascade)
  actions      ModerationAction[]

  @@index([reporterId])
  @@index([status])
  @@map("moderation_reports")
}

model ModerationAction {
  id           String               @id @default(uuid()) @db.Uuid
  adminId      String               @map("admin_id") @db.Uuid
  targetUserId String?              @map("target_user_id") @db.Uuid
  trackId      String?              @map("track_id") @db.Uuid
  playlistId   String?              @map("playlist_id") @db.Uuid
  commentId    String?              @map("comment_id") @db.Uuid
  reportId     String?              @map("report_id") @db.Uuid
  actionType   ModerationActionType @map("action_type")
  notes        String?              @db.Text
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz

  admin      User              @relation("AdminAction", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser User?             @relation("TargetUserAction", fields: [targetUserId], references: [id], onDelete: SetNull)
  track      Track?            @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playlist   Playlist?         @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  comment    Comment?          @relation(fields: [commentId], references: [id], onDelete: Cascade)
  report     ModerationReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([reportId])
  @@map("moderation_actions")
}

// =============================================================================
// Subscriptions & Billing
// =============================================================================

model SubscriptionPlan {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique
  name            String
  tier            SubscriptionTier
  priceCents      Int              @map("price_cents")
  billingInterval BillingInterval  @map("billing_interval")
  uploadLimit     Int              @default(-1) @map("upload_limit")
  features        Json             @default("{}") @db.JsonB
  isActive        Boolean          @default(true) @map("is_active")
  stripePriceId   String?          @map("stripe_price_id")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz

  subscriptions     UserSubscription[]
  availabilityRules TrackAvailabilityRule[]

  @@map("subscription_plans")
}

model UserSubscription {
  id                        String             @id @default(uuid()) @db.Uuid
  userId                    String             @map("user_id") @db.Uuid
  planId                    String             @map("plan_id") @db.Uuid
  stripeCustomerId          String?            @map("stripe_customer_id")
  stripeSubscriptionId      String?            @unique @map("stripe_subscription_id")
  status                    SubscriptionStatus @default(ACTIVE)
  cancelAtPeriodEnd         Boolean            @default(false) @map("cancel_at_period_end")
  currentPeriodStart        DateTime           @map("current_period_start") @db.Timestamptz
  currentPeriodEnd          DateTime           @map("current_period_end") @db.Timestamptz
  trialStart                DateTime?          @map("trial_start") @db.Timestamptz
  trialEnd                  DateTime?          @map("trial_end") @db.Timestamptz
  canceledAt                DateTime?          @map("canceled_at") @db.Timestamptz
  endedAt                   DateTime?          @map("ended_at") @db.Timestamptz
  paymentFailureAt          DateTime?          @map("payment_failure_at") @db.Timestamptz
  paymentFailureGraceEndsAt DateTime?          @map("payment_failure_grace_ends_at") @db.Timestamptz
  paymentMethodSummary      String?            @map("payment_method_summary") @db.VarChar(100)
  paymentMethod             Json?              @map("payment_method")
  createdAt                 DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices BillingInvoice[]
  payments PaymentEvent[]

  @@index([userId])
  @@index([status])
  @@map("user_subscriptions")
}

model BillingInvoice {
  id              String        @id @default(uuid()) @db.Uuid
  subscriptionId  String        @map("subscription_id") @db.Uuid
  stripeInvoiceId String        @unique @map("stripe_invoice_id")
  amountDueCents  Int           @map("amount_due_cents")
  amountPaidCents Int           @default(0) @map("amount_paid_cents")
  currency        String        @db.Char(3)
  status          InvoiceStatus @default(OPEN)
  dueAt           DateTime?     @map("due_at") @db.Timestamptz
  paidAt          DateTime?     @map("paid_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  subscription UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments     PaymentEvent[]

  @@index([subscriptionId])
  @@map("billing_invoices")
}

model PaymentEvent {
  id             String   @id @default(uuid()) @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  invoiceId      String?  @map("invoice_id") @db.Uuid
  stripeEventId  String   @unique @map("stripe_event_id")
  eventType      String   @map("event_type")
  payload        Json     @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  subscription UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice      BillingInvoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@map("payment_events")
}

// Tracks one free-trial redemption per user per paid plan.
// Used to prevent trial abuse (one trial per plan per lifetime).
model TrialRedemption {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @map("user_id") @db.Uuid
  planCode               String   @map("plan_code")
  redeemedAt             DateTime @default(now()) @map("redeemed_at") @db.Timestamptz
  providerSubscriptionId String?  @map("provider_subscription_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, planCode])
  @@index([userId])
  @@map("trial_redemptions")
}

// =============================================================================
// Offline Downloads
// =============================================================================

// Stores the Stripe customer ID for each user (created on first subscription).
// Keeps billing identity separate from the User model.
model UserBilling {
  userId           String @id @map("user_id") @db.Uuid
  stripeCustomerId String @unique @map("stripe_customer_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_billing")
}

// A saved payment method belonging to a user (card stored in Stripe).
// We store display metadata here so the UI can show card info without
// calling Stripe on every page load.
model PaymentMethod {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  stripePaymentMethodId String   @unique @map("stripe_payment_method_id")
  brand                 String   @db.VarChar(20)
  last4                 String   @db.Char(4)
  expMonth              Int      @map("exp_month")
  expYear               Int      @map("exp_year")
  cardholderName        String?  @map("cardholder_name") @db.VarChar(255)
  isDefault             Boolean  @default(false) @map("is_default")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_methods")
}

model OfflineDownload {
  userId       String   @map("user_id") @db.Uuid
  deviceId     String   @map("device_id") @db.Uuid
  trackId      String   @map("track_id") @db.Uuid
  downloadedAt DateTime @default(now()) @map("downloaded_at") @db.Timestamptz
  expiresAt    DateTime @map("expires_at") @db.Timestamptz

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  device UserDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  track  Track      @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([userId, deviceId, trackId])
  @@index([userId])
  @@index([expiresAt])
  @@map("offline_downloads")
}

// =============================================================================
// Analytics & Stats
// =============================================================================

model TrackDailyStat {
  trackId             String   @map("track_id") @db.Uuid
  statDate            DateTime @map("stat_date") @db.Date
  playCount           Int      @default(0) @map("play_count")
  uniqueListenerCount Int      @default(0) @map("unique_listener_count")
  likeCount           Int      @default(0) @map("like_count")
  repostCount         Int      @default(0) @map("repost_count")
  commentCount        Int      @default(0) @map("comment_count")
  downloadCount       Int      @default(0) @map("download_count")
  completionRate      Decimal  @default(0) @map("completion_rate") @db.Decimal(5, 4)

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([trackId, statDate])
  @@index([statDate])
  @@map("track_daily_stats")
}

model DailyPlatformMetric {
  metricDate        DateTime @id @map("metric_date") @db.Date
  activeUsers       Int      @default(0) @map("active_users")
  newUsers          Int      @default(0) @map("new_users")
  tracksUploaded    Int      @default(0) @map("tracks_uploaded")
  totalStorageBytes BigInt   @default(0) @map("total_storage_bytes")
  playThroughRate   Decimal  @default(0) @map("play_through_rate") @db.Decimal(5, 4)
  activeSubscribers Int      @default(0) @map("active_subscribers")

  @@map("daily_platform_metrics")
}

// =============================================================================
// Playback & Streaming
// =============================================================================

model PlaybackProgress {
  userId          String   @map("user_id") @db.Uuid
  trackId         String   @map("track_id") @db.Uuid
  positionSeconds Int      @map("position_seconds")
  durationSeconds Int      @map("duration_seconds")
  isCompleted     Boolean  @default(false) @map("is_completed")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([userId, trackId])
  @@map("playback_progress")
}

model PlayerSession {
  userId                String     @id @map("user_id") @db.Uuid
  currentTrackId        String?    @map("current_track_id") @db.Uuid
  positionSeconds       Int        @default(0) @map("position_seconds")
  isPlaying             Boolean    @default(false) @map("is_playing")
  volume                Float      @default(0.8)
  queueTrackIds         String[]   @map("queue_track_ids") @db.Uuid
  shuffle               Boolean    @default(false)
  repeatMode            RepeatMode @default(OFF) @map("repeat_mode")
  currentQueueIndex     Int        @default(0) @map("current_queue_index")
  realTracksSinceLastAd Int        @default(0) @map("real_tracks_since_last_ad")
  queueContext          Json?      @map("queue_context")
  updatedAt             DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentTrack Track? @relation("PlayerSessionTrack", fields: [currentTrackId], references: [id], onDelete: SetNull)

  @@map("player_sessions")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique
  deviceInfo   String   @map("device_info")
  ipAddress    String   @map("ip_address")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation("authSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// =============================================================================
// Reporting & Appeals (Module 8 & 11)
// =============================================================================

model Report {
  id          String           @id @default(uuid()) @db.Uuid
  reporterId  String           @map("reporter_id") @db.Uuid
  targetType  ReportTargetType @map("target_type")
  targetId    String           @map("target_id") @db.Uuid
  reason      ReportReason
  description String?          @db.Text
  status      ReportStatus     @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt  DateTime?        @map("resolved_at") @db.Timestamptz
  resolvedBy  String?          @map("resolved_by") @db.Uuid

  reporter        User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  appeals         Appeal[]
  adminResolution User?    @relation("ReportResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([targetId])
  @@index([status])
  @@index([targetType])
  @@index([createdAt])
  @@map("reports")
}

model Appeal {
  id              String       @id @default(uuid()) @db.Uuid
  reportId        String       @map("report_id") @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  message         String       @db.Text
  status          ReportStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt      DateTime?    @map("resolved_at") @db.Timestamptz
  resolutionNotes String?      @map("resolution_notes") @db.Text
  resolvedBy      String?      @map("resolved_by") @db.Uuid

  user            User   @relation("AppealUser", fields: [userId], references: [id], onDelete: Cascade)
  reportObject    Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  adminResolution User?  @relation("AppealResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([reportId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("appeals")
}
